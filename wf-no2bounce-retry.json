        "method": "GET",
        "url": "=https://connect.no2bounce.com/v2/n2b_validate_bulk?trackingId={{ $('No2Bounce Submit').first().json.data.trackingId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apitoken",
              "value": "264b139b091fad9c4330803c3f97c2f7"
            }
