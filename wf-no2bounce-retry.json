      "id": "n2b-retry-0009",
      "name": "No2Bounce Poll",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\nconst lead = $('Loop Over Items').item.json;\n\n// Check if completed\nconst isReady = r.overallStatus === 'Completed' || r.percent >= 100;\n\n// Count valid emails (Deliverable + any AcceptAll variants)\nconst deliverable = (r['Deliverable'] || 0) + (r['Deliverable/AcceptAll'] || 0);\nconst isValid = deliverable > 0;\n\nconst email_status = isReady\n  ? (isValid ? 'valid' : 'invalid')\n  : 'verification_timeout';\n\nreturn [{ json: { ...lead, email_status } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2240, 200],
      "id": "n2b-retry-0010",
      "name": "Parse Poll Result"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://nocodb-production-f802.up.railway.app/api/v1/db/data/noco/pb7f1zou786xyqc/mey3zgihq7o4at9/{{ $json.Id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-token",
              "value": "SqqM8YcDuzXGijg0oY7PvqTcPX5H-r2sYqbAOWTN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ status: $json.email_status === 'valid' ? 'enriched' : ($json.email_status === 'invalid' ? 'email invalid' : 'verification_timeout') }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2520, 200],
